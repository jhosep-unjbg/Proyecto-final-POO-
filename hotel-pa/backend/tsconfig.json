{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/services/memory", "src/main.ts",
    "src/db/**",
    "src/ormconfig.ts",
    "src/HotelSystem.ts",
    "src/repositories/file/FileDb.ts",
    "src/repositories/file/FileEstadiaRepository.ts",
    "src/repositories/file/FileHabitacionRepository.ts",
    "src/repositories/file/FilePagoRepository.ts",
    "src/repositories/file/FileReservaRepository.ts",
    "src/repositories/file/FileTarifaRepository.ts"
  ]
}