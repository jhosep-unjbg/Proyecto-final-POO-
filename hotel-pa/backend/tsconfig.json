{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/main.ts",
    "src/HotelSystem.ts",
    "src/repositories/file/FileDb.ts",
    "src/services/buildHotelSystem.ts",
    "src/services/memory/**"
  ]
}